<Page x:Class="CinemaManager.UI.WPF.HallDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
      Title="Деталі залу">
    <StackPanel>
        <TextBlock x:Name="HallName" FontSize="20" Margin="10"/>
        <TextBlock Text="Список сеансів" FontSize="16" Margin="10"/>
        <ListBox x:Name="SessionsList"  Margin="10" MouseDoubleClick="SessionsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Genre}"/>
                        <TextBlock Text="{Binding StartTime}"/>
                        <TextBlock Text="{Binding DurationMinutes}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Додати" Margin="10" Click="Add_Click"/>
        <Button Content="Назад" Margin="10" Click="Back_Click"/>
    </StackPanel>
</Page>
