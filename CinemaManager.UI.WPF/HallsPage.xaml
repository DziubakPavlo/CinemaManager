<Page x:Class="CinemaManager.UI.WPF.HallsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Кінозали">
    <StackPanel>
        <TextBlock Text="Список кінозалів" FontSize="20" Margin="10"/>
        <ListBox x:Name="HallsList" Margin="10" MouseDoubleClick="HallsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock Text="{Binding SeatCount}" FontSize="12" />
                        <TextBlock Text="{Binding Type}" FontSize="12" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Content="Додати" Margin="10" Click="Add_Click"/>
    </StackPanel>
</Page>
