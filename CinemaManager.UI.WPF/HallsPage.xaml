<Page x:Class="CinemaManager.UI.WPF.HallsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Кінозали">
    <StackPanel>
        <TextBlock Text="Список кінозалів" FontSize="20" Margin="10"/>
        <ListBox x:Name="HallsList" DisplayMemberPath="Name" Margin="10" MouseDoubleClick="HallsList_MouseDoubleClick"/>
        <Button Content="Додати" Margin="10" Click="Add_Click"/>
    </StackPanel>
</Page>
